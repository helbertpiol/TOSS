<RepairTroubleshootScreen>:
    canvas.before:
        Color:
            rgba: .94, .96, .98, 1
        Rectangle:
            pos: self.pos
            size: self.size

    BoxLayout:
        orientation: "vertical"

        BoxLayout:
            orientation: "horizontal"
            size_hint_y: None
            height: 108 if root.width < 650 else 82
            padding: (16, 12) if root.width < 650 else (26, 16)
            spacing: 10 if root.width < 650 else 14
            canvas.before:
                Color:
                    rgba: .08, .16, .28, 1
                Rectangle:
                    pos: self.pos
                    size: self.size

            BoxLayout:
                orientation: "vertical"
                Label:
                    text: "Repair/Troubleshoot ICT Equipment"
                    color: 1, 1, 1, 1
                    font_size: "18sp" if root.width < 650 else "22sp"
                    bold: True
                    halign: "left"
                    valign: "bottom"
                    text_size: self.size
                Label:
                    text: "Record technical repair assistance, findings, solution, and service result"
                    color: .76, .82, .90, 1
                    font_size: "11sp" if root.width < 650 else "13sp"
                    halign: "left"
                    valign: "top"
                    text_size: self.size

            Button:
                text: "Back"
                size_hint: None, None
                width: 84 if root.width < 650 else 105
                height: 44
                background_normal: ""
                background_color: .18, .28, .42, 1
                color: 1, 1, 1, 1
                on_release:
                    app.root.current = "technical_service_request"

        ScrollView:
            do_scroll_x: False

            BoxLayout:
                orientation: "vertical"
                size_hint_y: None
                height: self.minimum_height
                padding: 14 if root.width < 650 else 28
                spacing: 14 if root.width < 650 else 18

                GridLayout:
                    cols: 1 if root.width < 760 else 2
                    spacing: 14
                    size_hint_y: None
                    height: self.minimum_height

                    BoxLayout:
                        orientation: "vertical"
                        spacing: 6
                        size_hint_y: None
                        height: 78
                        Label:
                            text: "Equipment / Service"
                            color: .25, .30, .36, 1
                            font_size: "13sp"
                            size_hint_y: None
                            height: 24
                            halign: "left"
                            text_size: self.size
                        Spinner:
                            id: spn_equipment
                            text: "Select equipment / service"
                            values: []
                            size_hint_y: None
                            height: 48

                    BoxLayout:
                        orientation: "vertical"
                        spacing: 6
                        size_hint_y: None
                        height: 78
                        Label:
                            text: "SRF ID"
                            color: .25, .30, .36, 1
                            font_size: "13sp"
                            size_hint_y: None
                            height: 24
                            halign: "left"
                            text_size: self.size
                        TextInput:
                            id: txt_srf_id
                            hint_text: "Optional SRF number"
                            input_filter: "int"
                            multiline: False
                            size_hint_y: None
                            height: 48

                    BoxLayout:
                        orientation: "horizontal"
                        spacing: 10
                        padding: 0, 24, 0, 0
                        size_hint_y: None
                        height: 72
                        CheckBox:
                            id: chk_with_srf
                            size_hint: None, None
                            width: 44
                            height: 44
                        Label:
                            text: "With Service Request Form"
                            color: .25, .30, .36, 1
                            font_size: "14sp"
                            halign: "left"
                            valign: "middle"
                            text_size: self.size
                            on_touch_down:
                                if self.collide_point(*args[1].pos): chk_with_srf.active = not chk_with_srf.active

                BoxLayout:
                    orientation: "vertical"
                    spacing: 6
                    size_hint_y: None
                    height: 126
                    Label:
                        text: "Constructed Accomplishment Statement"
                        color: .25, .30, .36, 1
                        font_size: "13sp"
                        size_hint_y: None
                        height: 24
                        halign: "left"
                        text_size: self.size
                    TextInput:
                        id: txt_constructed
                        hint_text: "Example: Repaired 1 unit desktop computer of PITO"
                        multiline: True

                BoxLayout:
                    orientation: "vertical"
                    spacing: 6
                    size_hint_y: None
                    height: 126
                    Label:
                        text: "Problem Reported"
                        color: .25, .30, .36, 1
                        font_size: "13sp"
                        size_hint_y: None
                        height: 24
                        halign: "left"
                        text_size: self.size
                    TextInput:
                        id: txt_problem
                        hint_text: "Describe the problem reported by the requester"
                        multiline: True

                BoxLayout:
                    orientation: "vertical"
                    spacing: 6
                    size_hint_y: None
                    height: 126
                    Label:
                        text: "Findings"
                        color: .25, .30, .36, 1
                        font_size: "13sp"
                        size_hint_y: None
                        height: 24
                        halign: "left"
                        text_size: self.size
                    TextInput:
                        id: txt_findings
                        hint_text: "Technical findings"
                        multiline: True

                BoxLayout:
                    orientation: "vertical"
                    spacing: 6
                    size_hint_y: None
                    height: 126
                    Label:
                        text: "Solution / Action Taken"
                        color: .25, .30, .36, 1
                        font_size: "13sp"
                        size_hint_y: None
                        height: 24
                        halign: "left"
                        text_size: self.size
                    TextInput:
                        id: txt_solution
                        hint_text: "Actions taken or solution applied"
                        multiline: True


                GridLayout:
                    cols: 1 if root.width < 760 else 2
                    spacing: 14
                    size_hint_y: None
                    height: self.minimum_height

                    BoxLayout:
                        orientation: "vertical"
                        spacing: 6
                        size_hint_y: None
                        height: 78
                        Label:
                            text: "Unit Quantity"
                            color: .25, .30, .36, 1
                            font_size: "13sp"
                            size_hint_y: None
                            height: 24
                            halign: "left"
                            text_size: self.size
                        TextInput:
                            id: txt_unit_qty
                            text: "1"
                            input_filter: "int"
                            multiline: False
                            size_hint_y: None
                            height: 48

                    BoxLayout:
                        orientation: "vertical"
                        spacing: 6
                        size_hint_y: None
                        height: 78
                        Label:
                            text: "Unit UOM"
                            color: .25, .30, .36, 1
                            font_size: "13sp"
                            size_hint_y: None
                            height: 24
                            halign: "left"
                            text_size: self.size
                        Spinner:
                            id: spn_unit_uom
                            text: "unit"
                            values: ["unit", "units", "request", "requests", "set", "sets"]
                            size_hint_y: None
                            height: 48

                BoxLayout:
                    orientation: "vertical"
                    spacing: 6
                    size_hint_y: None
                    height: 78
                    Label:
                        text: "Service Result"
                        color: .25, .30, .36, 1
                        font_size: "13sp"
                        size_hint_y: None
                        height: 24
                        halign: "left"
                        text_size: self.size
                    Spinner:
                        id: spn_status
                        text: "Select result"
                        values: []
                        size_hint_y: None
                        height: 48

                BoxLayout:
                    orientation: "vertical"
                    spacing: 6
                    size_hint_y: None
                    height: 104
                    Label:
                        text: "Remarks"
                        color: .25, .30, .36, 1
                        font_size: "13sp"
                        size_hint_y: None
                        height: 24
                        halign: "left"
                        text_size: self.size
                    TextInput:
                        id: txt_remarks
                        hint_text: "Optional remarks"
                        multiline: True

                BoxLayout:
                    spacing: 12
                    size_hint_y: None
                    height: 112 if root.width < 650 else 52
                    orientation: "vertical" if root.width < 650 else "horizontal"
                    Label:
                        id: lbl_message
                        text: ""
                        color: .10, .36, .72, 1
                        font_size: "14sp"
                        halign: "left"
                        valign: "middle"
                        text_size: self.size
                    Button:
                        text: "Save Record"
                        size_hint_x: 1 if root.width < 650 else None
                        width: self.parent.width if root.width < 650 else 150
                        size_hint_y: None
                        height: 52
                        background_normal: ""
                        background_color: .10, .36, .72, 1
                        color: 1, 1, 1, 1
                        on_release:
                            root.save_repair_record()
