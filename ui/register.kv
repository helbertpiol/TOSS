<RegisterScreen>:

    canvas.before:

        Color:
            rgba:.96,.97,.98,1

        Rectangle:
            pos:self.pos
            size:self.size

    FloatLayout:

        BoxLayout:

            orientation:"vertical"

            size_hint:.50,.85

            pos_hint:{"center_x":.5,"center_y":.5}

            spacing:12

            padding:30

            canvas.before:

                Color:
                    rgba:1,1,1,1

                RoundedRectangle:
                    pos:self.pos
                    size:self.size
                    radius:[15]

            Label:

                text:"Create Account"

                font_size:"30sp"

                bold:True

                color:.15,.15,.3,1

            TextInput:

                id: txt_fullname

                hint_text:"Full Name"

                multiline: False

                size_hint_y: None

                height: 45

            TextInput:

                id: txt_username

                hint_text:"Username"

                multiline: False

                size_hint_y: None

                height: 45

            Spinner:
                id: spn_role

                text:"Select Role"

                values:["Administrator","Technical Staff"]

                size_hint_y: None

                height: 45

            TextInput:

                id: txt_password

                hint_text:"Password"

                multiline: False

                size_hint_y: None

                height: 45

                password:True

            TextInput:

                id: txt_confirm_password

                hint_text:"Confirm Password"

                multiline: False

                size_hint_y: None

                height: 45

                password:True

            Label:

                id: lbl_message

                text: ""

                size_hint_y: None

                height: 30

            Button:
                id: btn_username

                text:"REGISTER"

                size_hint_y:None

                height:55

                background_normal:""

                background_color:.08,.42,.82,1

                on_release:

                    root.register()

            Button:
                id: btn_back

                text:"BACK"

                size_hint_y:None

                height:55

                background_normal:""

                background_color:.08,.42,.82,1

                on_release:

                    root.go_back()
