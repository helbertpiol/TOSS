<LoginScreen>:

    canvas.before:
        Color:
            rgba: 0.96,0.97,0.98,1

        Rectangle:
            pos: self.pos
            size: self.size

    FloatLayout:

        BoxLayout:

            orientation: "vertical"

            size_hint: .45,.75

            pos_hint: {"center_x":.5,"center_y":.5}

            spacing: 15

            padding: 30

            canvas.before:

                Color:
                    rgba:1,1,1,1

                RoundedRectangle:
                    pos:self.pos
                    size:self.size
                    radius:[15]

            Widget:
                size_hint_y:.2

            Label:

                text:"TOSS"

                font_size:"40sp"

                bold:True

                color:.1,.2,.4,1

            Label:

                text:"Technical Operations Support Service"

                font_size:"14sp"

                color:.4,.4,.4,1

            TextInput:

                id:txt_username

                hint_text:"Username"

                multiline:False

                size_hint_y:None

                height:50

            TextInput:

                id:txt_password

                hint_text:"Password"

                password:True

                multiline:False

                size_hint_y:None

                height:50


            BoxLayout:

                size_hint_y:None

                height:40

                spacing:10

                CheckBox:

                    id: chk_remember

                    size_hint_x:None

                    width:40

                Label:

                    text:"Remember Me"

                    color:.2,.2,.2,1

                    font_size:"14sp"

                    halign:"left"

                    valign:"middle"

                    text_size:self.size

                    on_touch_down:

                        if self.collide_point(*args[1].pos): chk_remember.active = not chk_remember.active

            Button:

                text:"LOGIN"

                size_hint_y:None

                height:55

                background_normal:""

                background_color:.08,.42,.82,1

                on_release:

                    root.login()

            Button:

                text:"REGISTER"

                size_hint_y:None

                height:55

                background_normal:""

                background_color:.08,.42,.82,1

                on_release:

                    app.root.current = "register"

            Label:

                id: lbl_error

                text: ""

                color: 1, 0.1, 0.1, 1

                size_hint_y: None

                height: 30

            Widget:
